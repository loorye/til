# デモ用: true の場合は外部APIを呼ばずに擬似レスポンスを返す
MOCK_MODE=true
NEXT_PUBLIC_MOCK_MODE=true

# API keys (MOCK_MODE=false の場合に設定)
# ローカル開発時は .env に直接記載。本番(Amplify)では SSM Parameter Store から取得。
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Basic認証 (本番では SSM Parameter Store から取得)
AUTH_USERNAME=
AUTH_PASSWORD=
DISABLE_AUTH=false

# AWS認証 (ローカル開発時のみ。Amplify上ではIAMロールを使用)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN= # optional (assume roleの場合)

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
GEMINI_MODEL=gemini-1.0-pro
